# ============================================================
# Xstream Solution — ตัวอย่างไฟล์ตั้งค่า
# คัดลอกเป็น .env แล้วใส่ค่าจริง จากนั้นรัน:  npm run config:gen
# ============================================================

# ----- Firebase (จาก Firebase Console > Project settings) -----
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# ----- Database (MySQL) — ความลับฝั่ง server เท่านั้น -----
DB_HOST=your-db-host.ondigitalocean.com
DB_PORT=25060
DB_USER=your-user
DB_PASSWORD=your-password
DB_NAME=xstream2_solution
DB_SSL=true

# ----- App config -----
IMS_BACKEND=sql
SQL_TABLE_PREFIX=xstream2_

# ----- Super Admin เริ่มต้น -----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ----- TikTok Login Kit (OAuth 2.0) — จาก developers.tiktok.com -----
# CLIENT_SECRET เป็นความลับฝั่ง server เท่านั้น (ห้าม commit ค่าจริง)
# REDIRECT_URI ต้องตรงกับที่ลงทะเบียนไว้ใน TikTok app (ใช้ origin ของเว็บ + path)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8091/
TIKTOK_SCOPES=user.info.basic,user.info.profile,user.info.stats,video.list
